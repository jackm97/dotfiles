# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

SCRIPT_DIR=/home/jack/.config/i3blocks/scripts

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=$SCRIPT_DIR/$BLOCK_NAME/$BLOCK_NAME
separator_block_width=15
markup=none


# Generic media player support
#
# This displays "ARTIST - SONG" if a music is playing.
# Supported players are: spotify, vlc, audacious, xmms2, mplayer, and others.
# Set to %any to automatically pick (Requires playerctl >=2.1.1)
[mediaplayer]
color=#F8BD96
label=♪ 
#command=mediaplayer
# This picks any player, with vlc as first, and spotify as last choice
instance=spotify
interval=1
#signal=10

[cpu_usage]
interval=1
LABEL= 
#min_width=CPU: 100.00%
#T_WARN=50
#T_CRIT=80
#DECIMALS=2
COLOR_NORMAL=#ABE9B3
COLOR_WARN=#FAE3B0
COLOR_CRIT=#F28FAD
separator=false

[temperature]
color=#89DCEB
label=
interval=1
#T_WARN=70
#T_CRIT=90
SENSOR_CHIP="k10temp-pci-00c3"

[gpu-load2]
color=#F2CDCD
label= 
## The above icon is a custom font I made that I can't share due to licensing
#label=GPU 
interval=1
#L_WARN=70
#L_CRIT=90
WARN_COLOR="#FAE3B0" 
CRIT_COLOR="#F28FAD"
separator=false

[gpu-temperature]
color=#F5C2E7
#T_WARN=70
#T_CRIT=90
WARN_COLOR="#FAE3B0" 
CRIT_COLOR="#F28FAD"
interval=1

[battery]
color=#F5E0DC
#command=$SCRIPT_DIR/battery
interval=1
#LABEL=BAT
LABEL= 
#BAT_NUMBER=0

[calcurse-dropdown]
color=#F5E0DC
#command=$SCRIPT_DIR/calendar
interval=1
LABEL= 
DATEFMT=+%b %d, %Y -- %I:%M:%S

[dunst]
interval=once
format=json
markup=pango
MUTE_COLOR=#F5E0DC
DEFAULT_COLOR=#F5E0DC
#min_width=50
#align=center
signal=10
separator=false

[caffiene]
interval=once
format=json
markup=pango
CAF_COLOR=#F5E0DC
DECAF_COLOR=#F5E0DC
#min_width=50
#align=center
signal=20
separator=false

[shutdown_menu]
color=#F5E0DC
command=sh ~/.config/rofi/powermenu/powermenu.sh
full_text=
separator=false

[pactl-volume]
color=#F5E0DC
interval=persist
markup=pango
#signal=1
## If SUBSCRIBE=1, set interval=persist
SUBSCRIBE=1
## Warning color for volume >100%"
WARN_COLOR=#F8B63F
## Warning color for volume >150%
CRIT_COLOR=#FF0054
separator=false
min_width=18
