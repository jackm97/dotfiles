# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod1
set $altmod Mod4

# Input settings
input * {
    xkb_layout "us"
    scroll_factor 1
}

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
#font pango:icomoon, Font Awesome 5, IBM Plex Mono 12
#font -misc-fixed-medium-r-normal--13-120-75-75-C-70-iso10646-1
#font pango:icomoon, Font Awesome 5, IBM Plex Mono 12
  
#font -misc-fixed-medium-r-normal--13-120-75-75-C-70-iso10646-1
font pango:Cantarell, icomoon, Font Awesome 5 Free Solid 12


# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex-autostart --autostart dex -s ~/.config/autostart/:/etc/xdg/autostart/ --environment sway

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.

# Inactivity hooks: screen lock, suspend 
exec_always --no-startup-id pkill swayidle 
exec_always --no-startup-id sleep .1 && sh ~/.config/sway/swayidle-start.sh
bindsym $mod+Shift+x exec --no-startup-id pkill -RTMIN+20 i3blocks   


# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
# exec --no-startup-id nm-applet --indicator

# Pipewire-pulse
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute 0 toggle && pkill -RTMIN+1 i3blocks
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume 0 -5% && pkill -RTMIN+1 i3blocks
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume 0 +5% && pkill -RTMIN+1 i3blocks

# Media player controls
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioPause exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# start a terminal
bindsym $mod+Return exec --no-startup-id kitty -d ~

# kill focused window
bindsym $mod+Shift+q kill

# screenshot
bindsym --release Print exec --no-startup-id grimshot --notify save screen 
bindsym Shift+Print exec --no-startup-id grimshot --notify save area

# change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+h split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+Shift+a focus child

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1: " 
set $ws2 "2:"
set $ws3 "3:"
set $ws4 "4: / "
set $ws5 "5:"
set $ws6 "6:"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"


# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# switch to neighboring workspace
bindsym $mod+Control+Left workspace prev
bindsym $mod+Control+Right workspace next

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
bindsym $mod+Shift+c reload

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"


# start dmenu/rofi (a program launcher)
bindsym $mod+d exec --no-startup-id "sh ~/.config/rofi/launchers/colorful/launcher.sh run"
bindcode --release 133 exec --no-startup-id "sh ~/.config/rofi/launchers/colorful/launcher.sh drun"
bindsym $mod+Tab exec --no-startup-id "sh ~/.config/rofi/launchers/colorful/launcher.sh window"

# powermenu
bindsym $mod+x exec --no-startup-id "sh ~/.config/rofi/powermenu/powermenu.sh"

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
exec --no-startup-id ~/.config/i3blocks/pactl-volume/pactl-volume
bar {
  icon_theme Papirus
  position top
  status_command i3blocks
  tray_padding 4
  strip_workspace_numbers yes

  workspace_min_width 50
  colors {
    background #000000
    statusline #B6E0E5
    separator  #EDEDED

    focused_workspace  #B576BC #B576BC #FFFFFF
    active_workspace   #B576BC #B576BC #FFFFFF
    inactive_workspace #000000 #000000 #FFFFFF
    urgent_workspace   #FF0054 #FF0054 #FFFFFF
    binding_mode       #FF0054 #FF0054 #FFFFFF
  }
}

# Window Colors
# class                 border  bground text    indicator child_border
client.focused          #67BEE3 #67BEE3 #FFFFFF #BAFFAA   #BAFFAA
client.focused_inactive #67BEE3 #67BEE3 #FFFFFF #000000   #000000
client.unfocused        #000000 #000000 #EDEDED #000000   #000000
client.urgent           #FF0054 #FF0054 #FFFFFF #900000   #FF0054
client.placeholder      #000000 #000000 #FFFFFF #000000   #000000

client.background       #FFFFFF

# Background
output "*" bg "~/.config/i3/wallpaper.jpg" fill
# Display
output Virtual-1 pos 0 0 res 2048 1152
# Screen Brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightlight -i 10000 && notify-send "$(brightlight -r)" -h string:x-canonical-private-synchronous:backlight-notify
bindsym XF86MonBrightnessDown exec --no-startup-id brightlight -d 10000 && notify-send "$(brightlight -r)" -h string:x-canonical-private-synchronous:backlight-notify

# gaps
# You can also use any non-zero value if you'd like to have a border
for_window [class=".*"] border pixel 5
gaps inner 10
gaps outer 10

# polkit
exec --no-startup-id /usr/libexec/polkit-gnome-authentication-agent-1


# clipboard
exec wl-paste -t text --watch clipman store --no-persist

# Window Workspaces
for_window [app_id="firefox"] move to workspace $ws1
for_window [class="GitKraken"] move to workspace $ws3
for_window [class="jetbrains-pycharm"] move to workspace $ws3
for_window [class="jetbrains-clion"] move to workspace $ws3
for_window [class="MATLAB R2021b - academic use"] move to workspace $ws3
for_window [class="Microsoft Teams - Preview"] move to workspace $ws4
for_window [class="Spotify"] move to workspace $ws4
for_window [class="discord"] move to workspace $ws4
for_window [class="Evolution"] move to workspace $ws4
for_window [class="zoom"] move to workspace $ws4
for_window [class="Evolution.bin"] move to workspace $ws4
for_window [app_id="pavucontrol"] move to workspace $ws4
for_window [class="Virt-manager"] move to workspace $ws6
for_window [class="VirtualBox Manager"] move to workspace $ws6

# Floating Windows
for_window [class="Gpick"] floating enable 
for_window [class="Blueman-manager"] floating enable 
for_window [class="Matplotlib"] floating enable
for_window [app_id="org.gnome.Software"] floating enable
for_window [title="^zoom$" class="[zoom]*"] floating enable
for_window [app_id="thunar"] floating enable, resize set 45 ppt 40 ppt, move position 25 ppt 30 ppt

# Disable mouse focus
focus_follows_mouse no

# Disable focus on window activaton
focus_on_window_activation urgent

# Calendar dropdown
for_window [app_id="gnome-calendar"] floating enable, resize set 27 ppt 35 ppt, move position 73 ppt 0 px
bindsym Mod4+c exec --no-startup-id "gnome-calendar && swaymsg \[app_id='gnome-calendar'\] move container to workspace current, focus"

# Extra shortcuts
bindsym $altmod+f exec --no-startup-id firefox
bindsym $altmod+n exec --no-startup-id kitty nvim
bindsym $altmod+t exec --no-startup-id thunar
bindsym $altmod+d exec --no-startup-id dunstctl set-paused toggle && pkill -SIGRTMIN+10 i3blocks 
# Thunar daemon
exec --no-startup-id thunar --daemon

# dunst
exec --no-startup-id dunst &

# xdg portal
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

